# Normalize line endings for all text files to LF in the repo
* text=auto eol=lf

# Explicitly LF for web/python source files
*.py    text eol=lf
*.js    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.csv   text eol=lf

# Binary files — never touch line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.pdf   binary
